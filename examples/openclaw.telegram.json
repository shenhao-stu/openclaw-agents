{
    "agents": {
        "list": [
            {
                "id": "planner",
                "name": "🧠 Designated Driver",
                "workspace": "~/.openclaw/agents/planner",
                "model": "zai/glm-5",
                "identity": {
                    "name": "🧠 Designated Driver"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@planner",
                        "planner"
                    ],
                    "historyLimit": 50
                }
            }
        ]
    },
    "bindings": [
        {
            "agentId": "planner",
            "match": {
                "channel": "telegram",
                "peer": {
                    "kind": "group",
                    "id": "-1001234567890"
                }
            }
        }
    ],
    "channels": {
        "telegram": {
            "groupPolicy": "open",
            "groups": {
                "-1001234567890": {
                    "requireMention": true,
                    "tools": {
                        "deny": [
                            "exec"
                        ]
                    }
                }
            }
        }
    },
    "messages": {
        "groupChat": {
            "historyLimit": 50
        }
    }
}