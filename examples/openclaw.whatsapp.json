{
    "agents": {
        "list": [
            {
                "id": "planner",
                "name": "🧠 Planner",
                "workspace": "~/.openclaw/agents/planner",
                "model": "zai/glm-5",
                "identity": {
                    "name": "🧠 Planner"
                },
                "groupChat": {
                    "mentionPatterns": [
                        "@planner",
                        "planner"
                    ],
                    "historyLimit": 50
                }
            }
        ]
    },
    "bindings": [
        {
            "agentId": "planner",
            "match": {
                "channel": "whatsapp",
                "peer": {
                    "kind": "group",
                    "id": "YOUR_GROUP_ID@g.us"
                }
            }
        }
    ],
    "channels": {
        "whatsapp": {
            "groupPolicy": "open",
            "groups": {
                "YOUR_GROUP_ID@g.us": {
                    "requireMention": true
                }
            },
            "dmPolicy": "pairing"
        }
    },
    "messages": {
        "groupChat": {
            "historyLimit": 50
        }
    }
}