    "tools": {
        "agentToAgent": {
            "enabled": true,
            "allow": [
                {
                    "from": "*",
                    "to": "planner"
                },
                {
                    "from": "planner",
                    "to": "*"
                },
                {
                    "from": "ideator",
                    "to": "critic"
                },
                {
                    "from": "critic",
                    "to": "ideator"
                },
                {
                    "from": "writer",
                    "to": "reviewer"
                },
                {
                    "from": "reviewer",
                    "to": "writer"
                }
            ]
        }
    }
}